{
  "name": "upload_wizard",
  "states": [
    "idle",
    "file-ready",
    "choosing-delivery",
    "choosing-share",
    "confirming",
    "encrypting",
    "uploading",
    "completing",
    "complete"
  ],
  "transitions": [
    {
      "from_state": "idle",
      "to_state": "file-ready",
      "trigger": "file_selected",
      "guard": "file_input_has_file",
      "security": ""
    },
    {
      "from_state": "file-ready",
      "to_state": "choosing-delivery",
      "trigger": "auto_advance",
      "guard": "needs_delivery_choice",
      "security": ""
    },
    {
      "from_state": "file-ready",
      "to_state": "choosing-share",
      "trigger": "auto_advance",
      "guard": "single_file_or_text",
      "security": ""
    },
    {
      "from_state": "choosing-delivery",
      "to_state": "choosing-share",
      "trigger": "click_next",
      "guard": "delivery_mode_selected",
      "security": ""
    },
    {
      "from_state": "choosing-share",
      "to_state": "confirming",
      "trigger": "select_share_mode",
      "guard": "share_card_clicked",
      "security": ""
    },
    {
      "from_state": "confirming",
      "to_state": "encrypting",
      "trigger": "click_encrypt_upload",
      "guard": "",
      "security": "plaintext_in_memory"
    },
    {
      "from_state": "encrypting",
      "to_state": "uploading",
      "trigger": "auto_advance",
      "guard": "encryption_complete",
      "security": "ciphertext_only"
    },
    {
      "from_state": "uploading",
      "to_state": "completing",
      "trigger": "auto_advance",
      "guard": "upload_complete",
      "security": ""
    },
    {
      "from_state": "completing",
      "to_state": "complete",
      "trigger": "auto_advance",
      "guard": "finalisation_complete",
      "security": "key_in_url"
    }
  ],
  "mermaid": "stateDiagram-v2\n    idle --> file-ready : file_selected [file_input_has_file]\n    file-ready --> choosing-delivery : auto_advance [needs_delivery_choice]\n    file-ready --> choosing-share : auto_advance [single_file_or_text]\n    choosing-delivery --> choosing-share : click_next [delivery_mode_selected]\n    choosing-share --> confirming : select_share_mode [share_card_clicked]\n    confirming --> encrypting : click_encrypt_upload\n    encrypting --> uploading : auto_advance [encryption_complete]\n    uploading --> completing : auto_advance [upload_complete]\n    completing --> complete : auto_advance [finalisation_complete]",
  "security_annotated": [
    {
      "from": "confirming",
      "to": "encrypting",
      "trigger": "click_encrypt_upload",
      "security": "plaintext_in_memory"
    },
    {
      "from": "encrypting",
      "to": "uploading",
      "trigger": "auto_advance",
      "security": "ciphertext_only"
    },
    {
      "from": "completing",
      "to": "complete",
      "trigger": "auto_advance",
      "security": "key_in_url"
    }
  ]
}